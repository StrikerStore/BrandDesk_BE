{
  "name": "helpdesk-backend",
  "version": "1.0.0",
  "description": "BrandDesk backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "npm run db:migrate && node src/config/seed_shopify_test.js && node src/config/seed_demo_threads.js && node src/index.js",
